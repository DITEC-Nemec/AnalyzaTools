{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/sqd.schema.json",
  "title": "SQD Narrative Algorithm Model",
  "type": "object",
  "required": [
    "algorithm",
    "steps"
  ],
  "properties": {
    "algorithm": {
      "$ref": "#/$defs/algorithmMeta"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      },
      "minItems": 1
    },
    "actors": {
      "type": "array",
      "description": "Katalóg aktérov dostupných pre algoritmus",
      "items": {
        "$ref": "#/$defs/actorEntry"
      }
    },
    "namespaceRef": {
      "type": "array",
      "description": "Katalóg namespacov pre definiciu referencii na entityty/funkcie, sqd, eventy definované v iných modeloch  ",
      "items": {
        "$ref": "#/$defs/namespaceEntity"
      },
      "uniqueItems": true,
      "contains": {
        "type": "object",
        "properties": {
          "alias": {
            "const": "local"
          },
          "sourceType": {
            "const": "current"
          }
        },
        "required": [
          "alias",
          "sourceType"
        ]
      }
    }
  },
  "$defs": {
    "algorithmMeta": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "behavior": {
          "$ref": "#/$defs/behavior"
        }
      }
    },
    "step": {
      "type": "object",
      "required": [
        "id",
        "type",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "legacyId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "step",
            "decision",
            "loop",
            "foreach",
            "operation",
            "waitEvent",
            "return",
            "stop",
            "block"
          ]
        },
        "text": {
          "type": "string"
        },
        "collection": {
          "type": "string"
        },
        "item": {
          "type": "string"
        },
        "operation": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/referenceOperation"
            }
          ]
        },
        "condition": {
          "$ref": "#/$defs/condition"
        },
        "branches": {
          "$ref": "#/$defs/branches"
        },
        "body": {
          "$ref": "#/$defs/body"
        },
        "waitEvent": {
          "$ref": "#/$defs/waitEvent"
        },
        "behavior": {
          "$ref": "#/$defs/behavior"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "decision"
              }
            }
          },
          "then": {
            "required": [
              "condition",
              "branches"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "loop"
              }
            }
          },
          "then": {
            "required": [
              "condition",
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "foreach"
              }
            }
          },
          "then": {
            "required": [
              "collection",
              "item",
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "operation"
              }
            }
          },
          "then": {
            "required": [
              "operation"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "waitEvent"
              }
            }
          },
          "then": {
            "required": [
              "waitEvent"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "block"
              }
            }
          },
          "then": {
            "required": [
              "body"
            ]
          }
        }
      ]
    },
    "condition": {
      "type": "object",
      "required": [
        "kind",
        "description",
        "check"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "entityRef",
            "variableRef",
            "operationRef",
            "simple"
          ]
        },
        "variableRef": {
          "type": "string",
          "description": "Názov vstupného parametra algoritmu (z algorithm.inputs). Použiť keď podmienka overuje hodnotu vstupu algoritmu.",
          "deprecated": true
        },
        "entityRef": {
          "$ref": "#/$defs/referenceEntity"
        },
        "operationRef": {
          "$ref": "#/$defs/referenceOperation",
          "description": "Referencia na entityFunction alebo sqd, ktorého návratovú hodnotu podmienka vyhodnocuje. Použiť keď podmienka závisí od výsledku volania, nie od priameho stavu atribútu."
        },
        "description": {
          "minLength": 0,
          "description": "Slovný biznesový popis toho, čo podmienka rieši — pre čitateľnosť a AI interpretáciu."
        },
        "check": {
          "type": "string",
          "enum": [
            "exists",
            "is null",
            "is not null",
            "equals",
            "not equals",
            "greater than",
            "less than"
          ]
        },
        "value": {
          "description": "Literálna hodnota, s ktorou sa porovnáva (pre check: equals / not equals / greater than / less than)."
        }
      },
      "anyOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "entityRef"
              }
            }
          },
          "then": {
            "required": [
              "entityRef"
            ],
            "not": {
              "required": [
                "operationRef",
                "variableRef"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "variableRef"
              }
            }
          },
          "then": {
            "required": [
              "variableRef"
            ],
            "not": {
              "required": [
                "entityRef",
                "operationRef"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "operationRef"
              }
            }
          },
          "then": {
            "required": [
              "operationRef"
            ],
            "not": {
              "required": [
                "entityRef",
                "variableRef"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "simple"
              }
            }
          },
          "then": {
            "required": [
              "description"
            ],
            "not": {
              "required": [
                "entityRef",
                "operationRef"
              ]
            }
          }
        }
      ]
    },
    "referenceEntity": {
      "type": "object",
      "required": [
        "namespaceAlias"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1,
          "description": "Alias namespace zo namespaceRef. Pre aktuálny súbor použi hodnotu local."
        },
        "entity": {
          "type": "string",
          "description": " referencovana entita"
        },
        "attribute": {
          "type": "string",
          "description": "atribút pre  referencovanu entitu"
        }
      }
    },
    "referenceOperation": {
      "type": "object",
      "required": [
        "kind"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "entityFunction",
            "sqd",
            "step",
            "event"
          ]
        },
        "stepRef": {
          "type": "string",
          "description": "zdroj step zmysle goto step"
        },
        "entityFunctionRef": {
          "$ref": "#/$defs/referenceEntityFunction",
          "description": "referencia na entityFunction, ktorej výsledok volania podmienka vyhodnocuje. Použiť keď podmienka závisí od výsledku volania, nie od priameho stavu atribútu."
        },
        "sqdRef": {
          "$ref": "#/$defs/referenceSqd",
          "description": "referencia na sqd, ktorej výsledok volania podmienka vyhodnocuje. Použiť keď podmienka závisí od výsledku volania, nie od priameho stavu atribútu."
        },
        "eventRef": {
          "$ref": "#/$defs/referenceEvent",
          "description": "referencia na udalosť, ktorej výsledok volania podmienka vyhodnocuje. Použiť keď podmienka závisí od výsledku volania, nie od priameho stavu atribútu."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "entityFunction"
              }
            }
          },
          "then": {
            "required": [
              "entityFunctionRef"
            ],
            "not": {
              "required": [
                "eventRef",
                "sqdRef",
                "stepRef"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "sqd"
              }
            }
          },
          "then": {
            "required": [
              "sqdRef"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "entityFunctionRef"
                  ]
                },
                {
                  "required": [
                    "stepRef"
                  ]
                },
                {
                  "required": [
                    "eventRef"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "step"
              }
            }
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "entityFunctionRef"
                  ]
                },
                {
                  "required": [
                    "sqdRef"
                  ]
                },
                {
                  "required": [
                    "eventRef"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "event"
              }
            }
          },
          "then": {
            "required": [
              "eventRef"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "entityFunctionRef"
                  ]
                },
                {
                  "required": [
                    "sqdRef"
                  ]
                },
                {
                  "required": [
                    "stepRef"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    "referenceEntityFunction": {
      "type": "object",
      "required": [
        "function"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1,
          "description": "Alias namespace zo namespaceRef. Pre aktuálny súbor použi hodnotu local."
        },
        "entity": {
          "type": "string",
          "description": "entita pre referencovanu funkciu"
        },
        "function": {
          "type": "string",
          "description": "funkcia pre referencovan=u funkciu"
        },

        "mapParameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterMap"
          },
          "description": "Priradenie premenných sqd do parametrov volania funkce/sqd (používá se pre mapovanie vstupov algoritmu na parametry volané funkce/sqd alebo pre mapovanie premenných z jedného kroku na parametry volané funkce/sqd)"
        }
      }
    },
    "referenceSqd": {
      "type": "object",
      "required": [
        "namespaceAlias"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1,
          "description": "Alias pre referencovaný namespace (používá sa pre rozlíšenie viacero referencií na rovnaký namespace)"
        },
        "mapParameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterMap"
          },
          "description": "Priradenie premenných sqd do parametrov volania funkce/sqd (používá se pre mapovanie vstupov algoritmu na parametry volané funkce/sqd alebo pre mapovanie premenných z jedného kroku na parametry volané funkce/sqd)"
        }
      
      }
    },
    "referenceEvent": {
      "type": "object",
      "required": [
        "namespaceAlias"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1,
          "description": "Alias pre referencovaný namespace (používá sa pre rozlíšenie viacero referencií na rovnaký namespace)"
        },
        "event": {
          "type": "string",
          "description": "udalost pre referencovanú udalost"
        },
        "mapParameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterMap"
          },
          "description": "Priradenie premenných sqd do parametrov volania funkce/sqd (používá se pre mapovanie vstupov algoritmu na parametry volané funkce/sqd alebo pre mapovanie premenných z jedného kroku na parametry volané funkce/sqd)"
        }
      }
    },
    "parameter": {
      "type": "object",
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "in",
            "out",
            "inout"
          ],
          "description": "Směr parametru (vstupní, výstupní nebo obojí)"
        },
        "namedType": {
          "$ref": "#/$defs/namedType",
          "description": "Odkaz na pomenovaný typ proměnné (obsahuje aj názov, ale primárne slúži pro definici typu a dalších vlastností proměnné)"
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "documentation": {
          "type": "string"
        }
      }
    },
    "simpleType": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "definition"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "annotation": {
          "$ref": "#/$defs/annotation"
        },
        "definition": {
          "$ref": "#/$defs/simpleTypeDefinition"
        }
      }
    },
    "simpleTypeDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restriction": {
          "$ref": "#/$defs/restriction"
        },
        "list": {
          "$ref": "#/$defs/list"
        },
        "union": {
          "$ref": "#/$defs/union"
        }
      },
      "oneOf": [
        {
          "required": [
            "restriction"
          ]
        },
        {
          "required": [
            "list"
          ]
        },
        {
          "required": [
            "union"
          ]
        }
      ]
    },
    "simpleTypeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespaceAlias",
        "simpleType"
      ],
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1,
          "description": "Alias namespace zo namespaceRef. Pre aktuálny súbor použi hodnotu local."
        },
        "simpleType": {
          "type": "string"
        }
      }
    },
    "restriction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base"
      ],
      "properties": {
        "base": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "string",
                "boolean",
                "decimal",
                "integer",
                "long",
                "int",
                "short",
                "byte",
                "nonNegativeInteger",
                "positiveInteger",
                "nonPositiveInteger",
                "negativeInteger",
                "float",
                "double",
                "date",
                "dateTime",
                "time",
                "duration",
                "anyURI",
                "QName",
                "ID",
                "IDREF",
                "token",
                "normalizedString"
              ]
            },
            {
              "$ref": "#/$defs/simpleTypeRef"
            }
          ]
        },
        "enumeration": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "uniqueItems": true
        },
        "pattern": {
          "type": "string"
        },
        "length": {
          "type": "integer",
          "minimum": 0
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        },
        "minInclusive": {
          "type": [
            "number",
            "string"
          ]
        },
        "maxInclusive": {
          "type": [
            "number",
            "string"
          ]
        },
        "minExclusive": {
          "type": [
            "number",
            "string"
          ]
        },
        "maxExclusive": {
          "type": [
            "number",
            "string"
          ]
        },
        "totalDigits": {
          "type": "integer",
          "minimum": 1
        },
        "fractionDigits": {
          "type": "integer",
          "minimum": 0
        },
        "whiteSpace": {
          "type": "string",
          "enum": [
            "preserve",
            "replace",
            "collapse"
          ]
        }
      }
    },
    "list": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "itemType"
      ],
      "properties": {
        "itemType": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "string",
                "boolean",
                "decimal",
                "integer",
                "long",
                "int",
                "short",
                "byte",
                "nonNegativeInteger",
                "positiveInteger",
                "nonPositiveInteger",
                "negativeInteger",
                "float",
                "double",
                "date",
                "dateTime",
                "time",
                "duration",
                "anyURI",
                "QName",
                "ID",
                "IDREF",
                "token",
                "normalizedString"
              ]
            },
            {
              "$ref": "#/$defs/simpleTypeRef"
            }
          ]
        }
      }
    },
    "union": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memberTypes"
      ],
      "properties": {
        "memberTypes": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "string",
                  "boolean",
                  "decimal",
                  "integer",
                  "long",
                  "int",
                  "short",
                  "byte",
                  "nonNegativeInteger",
                  "positiveInteger",
                  "nonPositiveInteger",
                  "negativeInteger",
                  "float",
                  "double",
                  "date",
                  "dateTime",
                  "time",
                  "duration",
                  "anyURI",
                  "QName",
                  "ID",
                  "IDREF",
                  "token",
                  "normalizedString"
                ]
              },
              {
                "$ref": "#/$defs/simpleTypeRef"
              }
            ]
          },
          "minItems": 1
        }
      }
    },
    "namedType": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Názov premennej"
        },
        "annotation": {
          "$ref": "#/$defs/annotation"
        },
        "type": {
          "type": "string",
          "enum": [
            "definition",
            "entityRef",
            "typeRef"
          ]
        },
        "definition": {
          "$ref": "#/$defs/simpleTypeDefinition"
        },
        "entityRef": {
          "$ref": "#/$defs/referenceEntity",
          "description": " entita, na ktorú atribút odkazuje (pre type: reference)"
        },
        "typeRef": {
          "$ref": "#/$defs/simpleTypeRef"
        },
        "nullable": {
          "type": "boolean",
          "default": true
        },
        "readOnly": {
          "type": "boolean",
          "description": "Atribút je len na čítanie / vypočítaný"
        },
        "multiplicity": {
          "type": "string",
          "description": "Určuje, zda proměnná reprezentuje jeden objekt nebo kolekci objektů (používá se pro rozlišení mezi jednotlivými hodnotami a kolekcemi, například pro rozlišení mezi jednoduchou proměnnou a kolekcí v rámci foreach)"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "entityRef"
              }
            }
          },
          "then": {
            "required": [
              "entityRef"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "typeRef"
              }
            }
          },
          "then": {
            "required": [
              "typeRef"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "definition"
              }
            }
          },
          "then": {
            "required": [
              "definition"
            ]
          }
        }
      ]
    },
    "parameterMap": {
      "type": "object",
      "required": [
        "parameter",
        "value"
      ],
      "properties": {
        "parameter": {
          "type": "string",
          "description": "Názov parametra"
        },
        "value": {
          "type": "string",
          "description": "Hodnota parametra (môže byť názov iného parametra, literálna hodnota alebo referencia na atribút entity vo formáte namespaceAlias.entity.attribute)"
        }
      }
    },
    "affectedEntities": {
      "type": "array",
      "description": "Entity a atribúty ktoré funkcia/krok čítá alebo mení, plus výstupné premenné - zjednotené s SQD algoritmi",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/entityImpact"},
          {"$ref": "#/$defs/output"}
        ]
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "variable": {
          "type": "string",
          "description": "Názov výstupnej premennej"
        },
        "description": {
          "type": "string",
          "description": "Voľný popis čo táta premenná reprezentuje"
        }
      },
      "required": [
        "variable"
      ]
    },
    "entityImpact": {
      "type": "object",
      "required": [
        "impact"
      ],
      "properties": {
        "entityRef": {
          "$ref": "#/$defs/referenceEntity",
          "description": "Referencovana entita a jej atribút - použiť ak ide o zmenu v entite domény"
        },
        "variableRef": {
          "type": "string",
          "description": "Názov premennej - použiť ak ide o premennu z predchádzajúceho kroku"
        },
        "impact": {
          "type": "string",
          "enum": [
            "read",
            "write",
            "affect"
          ],
          "description": "Typ vplyvu: read (čítanie), write (zapis), affect (iný vplyv)"
        },
        "note": {
          "type": "string",
          "description": "Detailný popis - podrobný text čo sa čita/zmení, prečo, a ďalší kontext (multiline podporované)"
        }
      },
      "anyOf": [
        {
          "required": [
            "entityRef",
            "impact"
          ]
        },
        {
          "required": [
            "variableRef",
            "impact"
          ]
        }
      ]
    },
    "branches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "when",
          "then"
        ],
        "properties": {
          "when": {
            "oneOf": [
              { "type": "boolean" },
              { "type": "string", "const": "otherwise" }
            ]
          },
          "then": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/step"
            }
          }
        }
      }
    },
    "body": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      },
      "minItems": 1
    },
    "waitEvent": {
      "type": "object",
      "properties": {
        "eventRef": {
          "$ref": "#/$defs/referenceEvent"
       
        },
        "code": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "text": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "code"
          ]
        },
        {
          "required": [
            "eventRef"
          ]
        }
      ]
    },
    "actorEntry": {
      "type": "object",
      "required": [
        "code",
        "meaning"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "user",
            "system",
            "external_system"
          ]
        },
        "meaning": {
          "type": "string"
        },
        "responsibilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "actorRef": {
      "type": "object",
      "required": [
        "namespaceAlias",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1,
          "description": "Alias namespace zo namespaceRef. Pre aktuálny súbor použi hodnotu local."
        },
        "actor": {
          "type": "string",
          "description": "Kód aktéra v danom namespace"
        }
      }
    },
    "behavior": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "postconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affectedEntities": {
          "$ref": "#/$defs/affectedEntities"
        },
        "actors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/actorRef"
          }
        }
      }
    },
    "namespaceEntity": {
      "type": "object",
      "required": [
        "alias",
        "filePath",
        "sourceType"
      ],
      "additionalProperties": false,
      "properties": {
        "alias": {
          "type": "string",
          "minLength": 1,
          "description": "Alias pre referencovaný namspace (používá se pre rozlíšenie viacero referencií na rovnaký namespace)"
        },
        "filePath": {
          "type": "string",
          "description": " referencovana subor v ktorom je definovaný daný namespace"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "current",
            "model",
            "sqd"
          ],
          "description": "Typ zdroja referencie pre jednoznačné vyhodnocovanie"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "sourceType": {
                "const": "current"
              }
            }
          },
          "then": {
            "properties": {
              "alias": {
                "const": "local"
              }
            },
            "required": [
              "alias"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "alias": {
                "const": "local"
              }
            }
          },
          "then": {
            "properties": {
              "sourceType": {
                "const": "current"
              }
            },
            "required": [
              "sourceType"
            ]
          }
        }
      ]
    }
  }
}