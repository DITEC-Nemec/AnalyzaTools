{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/unified.schema.json",
  "title": "Unified SQD Model + Algorithm Schema",
  "description": "Single source of truth combining domain models and algorithms with selective namespace imports",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "description": "Shared governance layer - accessible to all modules",
      "additionalProperties": false,
      "required": [
        "metadata",
        "namespaceRefList"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/$defs/governanceMetadataDef"
        },
        "namespaceRefList": {
          "type": "array",
          "description": "Global catalog of all available namespaces. The 'local' alias is implicit and always resolves to the current file - do not list it here.",
          "items": {
            "$ref": "#/$defs/namespaceDef"
          },
          "uniqueItems": true,
          "minItems": 1
        }
      }
    },
    "domain": {
      "type": "object",
      "description": "Business domain model with selective namespace imports",
      "additionalProperties": false,
      "required": [
        "metadata"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/$defs/governanceMetadataDef"
        },
        "importList": {
          "type": "array",
          "description": "Namespace aliases to import (from meta.namespaceRef). 'local' is implicit and must not be listed.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "example": [
            "SOSM",
            "Finance"
          ]
        },
        "entityList": {
          "type": "array",
          "description": "Business entities - can reference imported namespaces",
          "items": {
            "$ref": "#/$defs/entityDef"
          }
        },
        "typeList": {
          "type": "array",
          "description": "Custom type definitions",
          "items": {
            "$ref": "#/$defs/simpleTypeDef"
          }
        },
        "relationshipList": {
          "type": "array",
          "description": "Entity relationships within and across imported namespaces",
          "items": {
            "$ref": "#/$defs/relationshipDef"
          }
        },
        "eventGlossaryList": {
          "type": "array",
          "description": "Domain event catalog - events scoped to this domain, referenceable via namespaceRef",
          "items": {
            "$ref": "#/$defs/eventGlossaryEntryDef"
          }
        }
      }
    },
    "algorithm": {
      "type": "object",
      "description": "Algorithm definitions with selective namespace imports",
      "additionalProperties": false,
      "required": [
        "metadata"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/$defs/governanceMetadataDef"
        },
        "importList": {
          "type": "array",
          "description": "Namespace aliases to import (from meta.namespaceRef). 'local' is implicit and must not be listed.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "example": [
            "SOSM"
          ]
        },
        "algorithmList": {
          "type": "array",
          "description": "Algorithm/procedure definitions",
          "items": {
            "$ref": "#/$defs/algorithmDef"
          }
        }
      }
    },
    "dictionary": {
      "type": "object",
      "description": "Cross-domain catalog - terms, rules and actors shared across all domains",
      "additionalProperties": false,
      "required": [
        "metadata"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/$defs/governanceMetadataDef"
        },
        "importList": {
          "type": "array",
          "description": "Namespace aliases to import (from meta.namespaceRef). 'local' is implicit and must not be listed.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "example": [
            "SOSM"
          ]
        },
        "glossaryList": {
          "type": "array",
          "description": "Universal business term definitions",
          "items": {
            "$ref": "#/$defs/glossaryEntryDef"
          }
        },
        "businessRuleList": {
          "type": "array",
          "description": "Cross-domain business rules and constraints",
          "items": {
            "$ref": "#/$defs/businessRuleDef"
          }
        },
        "actorList": {
          "type": "array",
          "description": "Universal actor catalog - roles shared across all domains (user, system, external_system)",
          "items": {
            "$ref": "#/$defs/actorDef"
          }
        }
      }
    }
  },
  "$defs": {
    "governanceMetadataDef": {
      "type": "object",
      "description": "Module governance metadata",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Module name"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "description": "Model version (e.g., 1.0.0)"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "deprecated"
          ]
        }
      }
    },
    "namespaceDef": {
      "type": "object",
      "required": [
        "alias",
        "filePath",
        "sourceType"
      ],
      "additionalProperties": false,
      "properties": {
        "alias": {
          "type": "string",
          "minLength": 1,
          "description": "Alias for this namespace (used in imports and references)"
        },
        "filePath": {
          "type": "string",
          "description": "Path to file containing this namespace"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "model",
            "sqd"
          ],
          "description": "Source type for reference resolution"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "deprecated",
            "draft"
          ],
          "description": "Namespace governance status"
        }
      }
    },
    "entityDef": {
      "type": "object",
      "required": [
        "name",
        "attributeList"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique entity name (used in algorithms)"
        },
        "description": {
          "type": "string"
        },
        "entityType": {
          "type": "string",
          "enum": [
            "business_concept",
            "database_table",
            "code_list",
            "conceptual_system",
            "computational_system",
            "other"
          ]
        },
        "agregationStatus": {
          "type": "string",
          "enum": [
            "root",
            "leaf",
            "intermediate"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "deprecated"
          ]
        },
        "stateList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stateDef"
          }
        },
        "transitionList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transitionDef"
          }
        },
        "attributeList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attributeDef"
          }
        },
        "functionList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/functionDef"
          }
        }
      }
    },
    "attributeDef": {
      "type": "object",
      "required": [
        "variable"
      ],
      "properties": {
        "variable": {
          "$ref": "#/$defs/varDef"
        },
        "codeLabelList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/codeLabelDef"
          }
        }
      }
    },
    "varDef": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Variable name"
        },
        "annotation": {
          "$ref": "#/$defs/annotationDef"
        },
        "varType": {
          "type": "string",
          "enum": [
            "definition",
            "entityRef",
            "typeRef"
          ]
        },
        "definition": {
          "$ref": "#/$defs/typeDefinitionDef"
        },
        "entityRef": {
          "$ref": "#/$defs/entityRef"
        },
        "typeRef": {
          "$ref": "#/$defs/typeRef"
        },
        "nullable": {
          "type": "boolean",
          "default": true
        },
        "readOnly": {
          "type": "boolean"
        },
        "multiplicity": {
          "type": "string"
        }
      }
    },
    "entityRef": {
      "type": "object",
      "required": [
        "namespaceAlias"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1,
          "description": "Namespace alias from imports"
        },
        "entity": {
          "type": "string",
          "description": "Entity name in that namespace"
        }
      }
    },
    "typeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespaceAlias",
        "simpleType"
      ],
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1
        },
        "simpleType": {
          "type": "string"
        }
      }
    },
    "simpleTypeDef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "definition"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "annotation": {
          "$ref": "#/$defs/annotationDef"
        },
        "definition": {
          "$ref": "#/$defs/typeDefinitionDef"
        }
      }
    },
    "typeDefinitionDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restriction": {
          "$ref": "#/$defs/restrictionDef"
        }
      }
    },
    "restrictionDef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base"
      ],
      "properties": {
        "base": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "string",
                "boolean",
                "decimal",
                "integer",
                "long",
                "int",
                "short",
                "byte",
                "nonNegativeInteger",
                "positiveInteger",
                "nonPositiveInteger",
                "negativeInteger",
                "float",
                "double",
                "date",
                "dateTime",
                "time",
                "duration",
                "anyURI",
                "QName",
                "ID",
                "IDREF",
                "token",
                "normalizedString"
              ]
            },
            {
              "$ref": "#/$defs/typeRef"
            }
          ]
        },
        "enumerationList": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "uniqueItems": true
        },
        "pattern": {
          "type": "string"
        },
        "length": {
          "type": "integer",
          "minimum": 0
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        },
        "minInclusive": {
          "type": [
            "number",
            "string"
          ]
        },
        "maxInclusive": {
          "type": [
            "number",
            "string"
          ]
        },
        "minExclusive": {
          "type": [
            "number",
            "string"
          ]
        },
        "maxExclusive": {
          "type": [
            "number",
            "string"
          ]
        },
        "totalDigits": {
          "type": "integer",
          "minimum": 1
        },
        "fractionDigits": {
          "type": "integer",
          "minimum": 0
        },
        "whiteSpace": {
          "type": "string",
          "enum": [
            "preserve",
            "replace",
            "collapse"
          ]
        }
      }
    },
    "roleDef": {
      "type": "object",
      "required": [
        "entityRef"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Role name"
        },
        "multiplicity": {
          "type": "string",
          "description": "Multiplicity (e.g., 1, 0..1, 1..*, *)"
        },
        "entityRef": {
          "$ref": "#/$defs/entityRef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "relationshipDef": {
      "type": "object",
      "required": [
        "relationshipType",
        "startRoleRef",
        "endRoleRef"
      ],
      "properties": {
        "relationshipType": {
          "type": "string",
          "enum": [
            "contains",
            "references",
            "belongs_to",
            "aggregates"
          ]
        },
        "startRoleRef": {
          "$ref": "#/$defs/roleDef"
        },
        "endRoleRef": {
          "$ref": "#/$defs/roleDef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "functionDef": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "parameterList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterDef"
          }
        },
        "behavior": {
          "$ref": "#/$defs/behaviorDef"
        }
      }
    },
    "parameterDef": {
      "type": "object",
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "in",
            "out",
            "inout"
          ]
        },
        "variable": {
          "$ref": "#/$defs/varDef"
        }
      }
    },
    "behaviorDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "preconditionList": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "postconditionList": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errorEventList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/errorEventDef"
          }
        },
        "affectedEntityList": {
          "$ref": "#/$defs/affectedEntityList"
        },
        "actorRefList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/actorRef"
          }
        }
      }
    },
    "errorEventDef": {
      "type": "object",
      "required": [
        "condition",
        "eventRef"
      ],
      "additionalProperties": false,
      "properties": {
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "eventRef": {
          "$ref": "#/$defs/eventRef"
        },
        "action": {
          "type": "string",
          "enum": [
            "emit",
            "fallback",
            "return",
            "exception",
            "retry",
            "skip",
            "compensate"
          ],
          "default": "emit"
        },
        "fallbackStepRef": {
          "type": "string"
        },
        "returnValue": {
          "type": "string"
        },
        "exceptionMessage": {
          "type": "string"
        },
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "backoffStrategy": {
          "type": "string",
          "enum": [
            "fixed",
            "linear",
            "exponential"
          ]
        },
        "delayMs": {
          "type": "integer",
          "minimum": 0
        },
        "skipToStepRef": {
          "type": "string"
        },
        "compensationStepRef": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "fallback"
              }
            }
          },
          "then": {
            "required": [
              "fallbackStepRef"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "return"
              }
            }
          },
          "then": {
            "required": [
              "returnValue"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "exception"
              }
            }
          },
          "then": {
            "required": [
              "exceptionMessage"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "retry"
              }
            }
          },
          "then": {
            "required": [
              "maxAttempts"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "compensate"
              }
            }
          },
          "then": {
            "required": [
              "compensationStepRef"
            ]
          }
        }
      ]
    },
    "affectedEntityList": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/entityImpactDef"
          },
          {
            "$ref": "#/$defs/outputDef"
          }
        ]
      }
    },
    "entityImpactDef": {
      "type": "object",
      "required": [
        "impact"
      ],
      "properties": {
        "attributeRef": {
          "$ref": "#/$defs/attributeRef"
        },
        "variableRef": {
          "type": "string"
        },
        "impact": {
          "type": "string",
          "enum": [
            "read",
            "write",
            "affect"
          ]
        },
        "note": {
          "type": "string"
        }
      }
    },
    "outputDef": {
      "type": "object",
      "required": [
        "variable"
      ],
      "properties": {
        "variable": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "attributeRef": {
      "type": "object",
      "required": [
        "namespaceAlias"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1
        },
        "entity": {
          "type": "string"
        },
        "attribute": {
          "type": "string"
        }
      }
    },
    "actorRef": {
      "type": "object",
      "required": [
        "namespaceAlias",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1,
          "description": "Namespace alias from imports"
        },
        "actor": {
          "type": "string",
          "description": "Actor code"
        }
      }
    },
    "actorDef": {
      "type": "object",
      "required": [
        "code",
        "definition"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "actorType": {
          "type": "string",
          "enum": [
            "user",
            "system",
            "external_system"
          ]
        },
        "definition": {
          "type": "string"
        },
        "responsibilityList": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "glossaryEntryDef": {
      "type": "object",
      "required": [
        "term",
        "definition"
      ],
      "properties": {
        "term": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "relatedEntity": {
          "type": "string"
        }
      }
    },
    "eventGlossaryEntryDef": {
      "type": "object",
      "required": [
        "code",
        "definition"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "Event code (e.g., sosm-00)"
        },
        "title": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "recommendedAction": {
          "type": "string"
        }
      }
    },
    "businessRuleDef": {
      "type": "object",
      "required": [
        "code",
        "description"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "Rule identifier"
        },
        "description": {
          "type": "string",
          "description": "Rule statement in natural language"
        },
        "severity": {
          "type": "string",
          "enum": [
            "mandatory",
            "recommended",
            "informational"
          ]
        },
        "affectedEntityNameList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Entity names affected by this rule"
        }
      }
    },
    "algorithmDef": {
      "type": "object",
      "required": [
        "name",
        "stepList"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "parameterList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterDef"
          }
        },
        "behavior": {
          "$ref": "#/$defs/behaviorDef"
        },
        "stepList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stepDef"
          },
          "minItems": 1
        }
      }
    },
    "stepDef": {
      "type": "object",
      "required": [
        "id",
        "stepType",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "legacyId": {
          "type": "string"
        },
        "stepType": {
          "type": "string",
          "enum": [
            "step",
            "decision",
            "loop",
            "foreach",
            "operation",
            "return",
            "stop",
            "block"
          ]
        },
        "description": {
          "type": "string"
        },
        "sourceCollectionRef": {
          "type": "string"
        },
        "iteratorItemName": {
          "type": "string"
        },
        "operationRef": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/operationRef"
            }
          ]
        },
        "condition": {
          "$ref": "#/$defs/conditionDef"
        },
        "branchList": {
          "$ref": "#/$defs/branchList"
        },
        "subStepList": {
          "$ref": "#/$defs/subStepList"
        },
        "behavior": {
          "$ref": "#/$defs/behaviorDef"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "stepType": {
                "const": "decision"
              }
            }
          },
          "then": {
            "required": [
              "condition",
              "branchList"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "stepType": {
                "const": "loop"
              }
            }
          },
          "then": {
            "required": [
              "condition",
              "subStepList"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "stepType": {
                "const": "foreach"
              }
            }
          },
          "then": {
            "required": [
              "sourceCollectionRef",
              "iteratorItemName",
              "subStepList"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "stepType": {
                "const": "operation"
              }
            }
          },
          "then": {
            "required": [
              "operationRef"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "stepType": {
                "const": "block"
              }
            }
          },
          "then": {
            "required": [
              "subStepList"
            ]
          }
        }
      ]
    },
    "conditionDef": {
      "type": "object",
      "required": [
        "conditionType",
        "description",
        "operatorType"
      ],
      "properties": {
        "conditionType": {
          "type": "string",
          "enum": [
            "entityRef",
            "variableRef",
            "operationRef",
            "waitEvent",
            "simple"
          ]
        },
        "variableRef": {
          "type": "string",
          "deprecated": true
        },
        "attributeRef": {
          "$ref": "#/$defs/attributeRef"
        },
        "operationRef": {
          "$ref": "#/$defs/operationRef"
        },
        "waitEvent": {
          "$ref": "#/$defs/eventTriggerRef"
        },
        "description": {
          "minLength": 0
        },
        "operatorType": {
          "type": "string",
          "enum": [
            "exists",
            "is null",
            "is not null",
            "equals",
            "not equals",
            "greater than",
            "less than"
          ]
        },
        "value": {}
      }
    },
    "branchList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "when",
          "then"
        ],
        "properties": {
          "when": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "string",
                "const": "otherwise"
              }
            ]
          },
          "then": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/stepDef"
            }
          }
        }
      }
    },
    "subStepList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stepDef"
      },
      "minItems": 1
    },
    "eventTriggerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eventRef"
      ],
      "properties": {
        "eventRef": {
          "$ref": "#/$defs/eventRef"
        },
        "waitUntil": {
          "type": "string"
        },
        "timeoutAction": {
          "type": "string"
        }
      }
    },
    "operationRef": {
      "type": "object",
      "required": [
        "callType"
      ],
      "additionalProperties": false,
      "properties": {
        "callType": {
          "type": "string",
          "enum": [
            "entityFunction",
            "sqd",
            "step",
            "event"
          ]
        },
        "stepRef": {
          "type": "string"
        },
        "entityFunctionRef": {
          "$ref": "#/$defs/entityFunctionRef"
        },
        "sqdRef": {
          "$ref": "#/$defs/sqdRef"
        },
        "emitEventRef": {
          "$ref": "#/$defs/eventRef"
        }
      }
    },
    "entityFunctionRef": {
      "type": "object",
      "required": [
        "function"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1
        },
        "entity": {
          "type": "string"
        },
        "function": {
          "type": "string"
        },
        "parameterMapList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterMapDef"
          }
        }
      }
    },
    "sqdRef": {
      "type": "object",
      "required": [
        "namespaceAlias"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1
        },
        "parameterMapList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterMapDef"
          }
        }
      }
    },
    "eventRef": {
      "type": "object",
      "required": [
        "namespaceAlias"
      ],
      "additionalProperties": false,
      "properties": {
        "namespaceAlias": {
          "type": "string",
          "minLength": 1
        },
        "event": {
          "type": "string"
        },
        "parameterMapList": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterMapDef"
          }
        }
      }
    },
    "parameterMapDef": {
      "type": "object",
      "required": [
        "parameter",
        "value"
      ],
      "properties": {
        "parameter": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "transitionDef": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "trigger": {
          "$ref": "#/$defs/eventTriggerRef"
        },
        "condition": {
          "type": "string",
          "description": "Guard condition. Transition is allowed only if this condition is true."
        },
        "operationRef": {
          "$ref": "#/$defs/operationRef",
          "description": "Operation executed during the transition."
        },
        "priority": {
          "type": "integer",
          "default": 0
        },
        "automatic": {
          "type": "boolean",
          "default": false
        },
        "description": {
          "type": "string"
        }
      }
    },
    "stateDef": {
      "type": "object",
      "required": [
        "name",
        "stateType"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "stateType": {
          "type": "string",
          "enum": [
            "initial",
            "normal",
            "final",
            "choice",
            "junction",
            "error"
          ],
          "default": "normal"
        },
        "entryOperation": {
          "$ref": "#/$defs/operationRef"
        },
        "doOperation": {
          "$ref": "#/$defs/operationRef"
        },
        "exitOperation": {
          "$ref": "#/$defs/operationRef"
        },
        "isFinal": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "codeLabelDef": {
      "type": "object",
      "required": [
        "code"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "annotationDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "documentation": {
          "type": "string"
        }
      }
    }
  }
}